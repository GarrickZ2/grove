{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.11.9",
  "identifier": "com.grove.app",
  "build": {
    "beforeBuildCommand": "cd grove-web && npm run build",
    "frontendDist": "../grove-web/dist",
    "devUrl": "http://localhost:5173",
    "features": ["gui"]
  },
  "app": {
    "windows": [
      {
        "title": "Grove",
        "width": 1200,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "RWRzdHA3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3c=",
      "endpoints": [
        "https://raw.githubusercontent.com/GarrickZ2/grove/master/updater.json"
      ]
    }
  }
}
